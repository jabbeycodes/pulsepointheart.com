# PulsePoint Clinic - Environment variables
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local to git.
#
# These same variables also need to be set in the Vercel dashboard:
#   Vercel Project Settings -> Environment Variables

# ----------------------------------------------------------------------------
# Supabase (Pulsepoint project)
# ----------------------------------------------------------------------------
# Found in Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# "anon" public key - safe to expose to the browser. RLS protects the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# "service_role" key - SERVER ONLY. Bypasses RLS. NEVER commit. NEVER expose.
# Only used in API routes / server code that needs elevated privileges.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# Email notifications via Resend
# ----------------------------------------------------------------------------
# Create a Resend API key and verify the sender domain/address before production use.

RESEND_API_KEY=
NOTIFICATION_EMAIL=info@pulsepointheart.com
NOTIFICATION_FROM_EMAIL=PulsePoint Clinic <notifications@pulsepointheart.com>

# ----------------------------------------------------------------------------
# Blog automation
# ----------------------------------------------------------------------------
# Used by Vercel Cron to create weekly draft posts. Use a long random value.

CRON_SECRET=

# Drafts older than this many hours are auto-published by /api/blog/auto-publish.
BLOG_AUTO_PUBLISH_AFTER_HOURS=6
